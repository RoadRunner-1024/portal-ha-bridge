<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←  Back"
                android:backgroundTint="#37474F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Portal HA Bridge"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/onSurface"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/hint"
            android:fontFamily="monospace"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_grant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Missing Permissions"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_check_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check for Updates"
            android:backgroundTint="#37474F"
            android:layout_marginBottom="20dp" />

        <!-- MQTT Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MQTT Broker"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_host"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:hint="Host (e.g. 192.168.1.10)"
                android:inputType="textUri"
                android:textColor="@color/onSurface"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Port"
                android:inputType="number"
                android:textColor="@color/onSurface" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username (optional)"
            android:inputType="text"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (optional)"
            android:inputType="textPassword"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device name shown in Home Assistant"
            android:inputType="text"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home Assistant"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_ha_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="HA URL (e.g. http://192.168.1.10:8123)"
            android:inputType="textUri"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_ha_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="HA long-lived token (optional - for voice-assistant control)"
            android:inputType="textPassword"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="8dp" />


        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save &amp; Restart Service"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="16dp" />

        <!-- Test controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_sleep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Sleep"
                android:backgroundTint="#37474F"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_wake"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Wake"
                android:backgroundTint="#37474F" />
        </LinearLayout>

        <!-- Accessibility setup -->
        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Accessibility Service (for Sleep)"
            android:backgroundTint="#4A148C"
            android:layout_marginBottom="20dp" />

        <!-- Camera -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_camera_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Camera Settings"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_display_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Display &amp; Presence Settings"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="20dp" />

        <!-- Intercom -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intercom"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_intercom_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Intercom Settings"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="20dp" />

        <!-- Tap Sensitivity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Sensitivity"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_sensitivity_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/hint"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sensitive"
                android:textSize="11sp"
                android:textColor="@color/hint"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seek_sensitivity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="26" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Firm"
                android:textSize="11sp"
                android:textColor="@color/hint"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
