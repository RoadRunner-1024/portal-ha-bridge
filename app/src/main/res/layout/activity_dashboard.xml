<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- Left drawer (swipe from left edge to open) -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1A1A2E"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Portal HA Bridge"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:backgroundTint="#3A3A5C"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_reload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reload"
            android:backgroundTint="#3A3A5C" />

        <!-- Intercom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intercom"
            android:textColor="#AAB0FF"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_announce"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Hold to Announce"
            android:textStyle="bold"
            android:backgroundTint="#3949AB" />

        <TextView
            android:id="@+id/tv_intercom_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888FAA"
            android:textSize="11sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
