<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!--
        Granted at setup time via ADB:
            adb shell pm grant com.aeonos.portalha android.permission.WRITE_SECURE_SETTINGS
        Used to auto-enable our own AccessibilityService so sleep works without
        device admin or any user interaction in Settings.
    -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

    <!--
        Granted at setup time via ADB:
            adb shell pm grant com.aeonos.portalha android.permission.RECORD_AUDIO
        Used for ambient sound level sensor (measures amplitude only — audio is never stored).
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
        Granted at setup time via ADB:
            adb shell appops set com.aeonos.portalha WRITE_SETTINGS allow
        Used to read and set screen brightness.
    -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />

    <!--
        Granted at setup time via ADB:
            adb shell pm grant com.aeonos.portalha android.permission.CAMERA
        Used for optional camera streaming and motion detection.
        Required when Camera feature is enabled in the app.
    -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!--
        Granted at setup time via ADB:
            adb shell appops set com.aeonos.portalha SYSTEM_ALERT_WINDOW allow
        Used to keep a 1x1 transparent overlay on screen so the process stays in
        "visible" state, allowing the camera foreground service to open the camera
        even when another app is in the foreground (Portal blocks background camera
        access regardless of foregroundServiceType).
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
        Granted at setup time via ADB (optional — only for the Portal Presence sensor):
            adb shell pm grant com.aeonos.portalha android.permission.READ_LOGS
        Lets the app tail logcat to read Meta's own face-presence detection
        (PresenceManager heartbeat) and expose it to Home Assistant. READ_LOGS is a
        development-protection permission, so it can only be granted via ADB.
    -->
    <uses-permission android:name="android.permission.READ_LOGS" />

    <!--
        In-app updater: download the latest signed APK from GitHub releases and
        install it over the current app (same keystore). On Portals the in-Settings
        "install unknown apps" toggle is unreliable, so the provisioner grants the
        app-op directly:
            adb shell appops set com.aeonos.portalha REQUEST_INSTALL_PACKAGES allow
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:theme="@style/Theme.PortalHA"
        android:allowBackup="false"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".DashboardActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <activity
            android:name=".CameraSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".DisplaySettingsActivity"
            android:exported="false" />

        <activity
            android:name=".IntercomSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".IntercomButtonsActivity"
            android:exported="false" />

        <service
            android:name=".BridgeService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice|camera" />

        <!--
            AccessibilityService used solely for GLOBAL_ACTION_LOCK_SCREEN.
            Declares typeNone so it never intercepts UI events.
        -->
        <service
            android:name=".ScreenAccessibility"
            android:exported="true"
            android:label="@string/accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- PackageInstaller session callbacks for the in-app updater. -->
        <receiver
            android:name=".UpdateInstallReceiver"
            android:exported="false" />

        <!--
            portal-assistant ("Jarvis") tool-provider plugin. Exposes Portal controls
            (screen/camera/presence) and a Home Assistant passthrough as voice tools.
            Jarvis discovers it via the two meta-data strings (the public ToolContract);
            it's off until the user enables it in Jarvis Settings -> External tools, and
            AssistantToolProvider only accepts invokes from the assistant package.
        -->
        <provider
            android:name=".AssistantToolProvider"
            android:authorities="com.aeonos.portalha.tools"
            android:exported="true">
            <!--
                Values are INLINE literals, not @string/ references: the assistant reads them with
                metaData.getString(), and a @string/ reference comes back as a resource id (getString
                returns null), so the provider would be silently skipped. Literal strings always read back.
            -->
            <meta-data android:name="com.portal.assistant.tools" android:value="[{&quot;name&quot;:&quot;com.aeonos.portalha.set_screen&quot;,&quot;description&quot;:&quot;Turn this Meta Portal's display on (wake it) or off (sleep/lock the screen).&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{&quot;on&quot;:{&quot;type&quot;:&quot;boolean&quot;,&quot;description&quot;:&quot;true = wake the screen, false = turn the screen off.&quot;}},&quot;required&quot;:[&quot;on&quot;]}},{&quot;name&quot;:&quot;com.aeonos.portalha.set_camera&quot;,&quot;description&quot;:&quot;Turn this Portal's camera (the Home Assistant video stream) on or off.&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{&quot;on&quot;:{&quot;type&quot;:&quot;boolean&quot;,&quot;description&quot;:&quot;true = enable the camera, false = disable it.&quot;}},&quot;required&quot;:[&quot;on&quot;]}},{&quot;name&quot;:&quot;com.aeonos.portalha.get_presence&quot;,&quot;description&quot;:&quot;Check whether someone is currently present in front of this Portal (room occupancy).&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{}}},{&quot;name&quot;:&quot;com.aeonos.portalha.home_assistant_list&quot;,&quot;description&quot;:&quot;Discover Home Assistant devices/entities and their entity_id. Use this FIRST to find a device by name, then control it with home_assistant_service. Works for ALL devices (even ones not exposed to Assist). Filter with 'query' (matches the friendly name or id, e.g. 'thea' or 'bedroom') and/or 'domain' (e.g. 'light','switch','climate','lock','cover','media_player').&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{&quot;query&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Substring matched against entity name or id, e.g. 'thea', 'kitchen'. Optional.&quot;},&quot;domain&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Limit to one domain, e.g. 'light','switch','climate'. Optional.&quot;}}}},{&quot;name&quot;:&quot;com.aeonos.portalha.home_assistant_service&quot;,&quot;description&quot;:&quot;Control a Home Assistant entity by id (get the id from home_assistant_list). Works for any entity. Example: domain 'light', service 'turn_on', entity_id 'light.theas_light'.&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{&quot;domain&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Service domain, e.g. 'light','switch','scene','climate','lock','cover'.&quot;},&quot;service&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Service, e.g. 'turn_on','turn_off','toggle','set_temperature'.&quot;},&quot;entity_id&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Target entity id, e.g. 'light.theas_light'. Optional for services that need none.&quot;},&quot;data_json&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;Optional extra data as a JSON object string, e.g. {'brightness_pct': 50}.&quot;}},&quot;required&quot;:[&quot;domain&quot;,&quot;service&quot;]}},{&quot;name&quot;:&quot;com.aeonos.portalha.home_assistant&quot;,&quot;description&quot;:&quot;Send a natural-language command or question to Home Assistant Assist (e.g. 'is the garage open?'). NOTE: only reaches entities the user EXPOSED to Assist; if it says it can't find the device, use home_assistant_list then home_assistant_service instead.&quot;,&quot;parameters&quot;:{&quot;type&quot;:&quot;object&quot;,&quot;properties&quot;:{&quot;command&quot;:{&quot;type&quot;:&quot;string&quot;,&quot;description&quot;:&quot;The natural-language request or question.&quot;}},&quot;required&quot;:[&quot;command&quot;]}}]" />
            <meta-data android:name="com.portal.assistant.tools.summary" android:value="Control this Portal (screen, camera, presence) and your whole Home Assistant smart home by voice." />
        </provider>

    </application>
</manifest>
